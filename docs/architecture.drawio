        <!-- Legend -->
        <mxCell id="legend" value="Flow:  ① developer seeds/queries RDS over psql   ② Debezium reads WAL   ③ events land in Kafka topic   ④–⑤ plugin pulled from S3 via gateway endpoint   ⑥ logs to CloudWatch   ⑦ IAM role authorizes connector" style="text;html=1;strokeColor=#CED4DA;fillColor=#F8F9FA;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#5A6B7B;spacingLeft=8;" vertex="1" parent="1">
